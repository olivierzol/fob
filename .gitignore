# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# Built app bundle (produced by Scripts/build-app.sh)
fob.app/

# macOS
.DS_Store

# Editor / IDE
.vscode/

# Xcode (in case an app target is added later)
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/

# fob runtime data never lives in-tree (it's in ~/.fob), but guard anyway
*.sock
*.policy
audit.log
audit.head.sig

# Signing / notarization secrets — must never be committed. Prefer a keychain
# profile (xcrun notarytool store-credentials) so no secret lives on disk at all.
*.p8
*.p12
.env
.env.*

# Release artifacts (produced by Scripts/release.sh)
fob-*.zip
notarize.zip
